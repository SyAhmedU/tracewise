# Optional. Without it, Tracewise generates deterministic follow-up probes
# (the app is fully functional offline). With it, probes are AI-generated via Groq.
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Optional override. Defaults to the same model scalebase/journaltime use.
TRACEWISE_MODEL=llama-3.3-70b-versatile
